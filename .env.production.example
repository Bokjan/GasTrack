# ============================================
# GasTrack 生产环境配置
# ============================================
# 使用方式: 复制本文件为 .env.production 并填写实际值
#   cp .env.production.example .env.production
# ============================================

# ---------- 数据库 ----------
DB_USER=gastrack
DB_PASSWORD=              # ⚠️ 必填！请使用强密码
DB_NAME=gastrack

# ---------- JWT ----------
JWT_SECRET=               # ⚠️ 必填！使用 openssl rand -hex 32 生成

# ---------- 域名与 HTTPS ----------
DOMAIN=yourdomain.com     # ⚠️ 必填！你的域名
EMAIL=you@email.com       # ⚠️ 必填！Let's Encrypt 通知邮箱
CORS_ORIGINS=https://yourdomain.com  # 与 DOMAIN 保持一致

# ---------- 注册模式 ----------
# open = 公开注册 | invite_only = 邀请制 | closed = 关闭注册
REGISTRATION_MODE=invite_only

# ---------- 日志级别 ----------
LOG_LEVEL=info

# ---------- 前端 ----------
DEFAULT_LOCALE=zh-CN

# ---------- 端口映射 ----------
HTTP_PORT=80              # HTTP 端口（用于 HTTPS 301 跳转 + ACME 验证）
HTTPS_PORT=443            # HTTPS 端口

# ---------- 不启用 HTTPS？ ----------
# 如果外层有 CDN/负载均衡器做 SSL 终止，或仅用 HTTP：
#   1. 将 nginx/default-http-only.conf 替换 nginx/default.conf
#   2. 注释掉 HTTPS_PORT
#   3. 不需要运行 scripts/init-ssl.sh
