# ============================================
# GasTrack Frontend — 多阶段构建
# ============================================

# --- 构建阶段 ---
FROM node:22-alpine AS builder

# 安装 pnpm（v10 兼容 lockfile v9.0）
RUN corepack enable && corepack prepare pnpm@10 --activate

WORKDIR /build

# 先复制依赖描述文件，利用 Docker 缓存层
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY packages/shared/package.json ./packages/shared/
COPY packages/web/package.json ./packages/web/

RUN pnpm install --frozen-lockfile

# 复制源码
COPY packages/ ./packages/

# 构建参数（可通过 docker build --build-arg 或 compose 传入）
ARG VITE_API_BASE_URL=/api/v1
ARG VITE_DEFAULT_LOCALE=zh-CN

# 构建前端
RUN pnpm --filter @gastrack/web build

# --- 运行阶段 ---
FROM nginx:1.27-alpine

# 复制自定义 Nginx 配置
COPY nginx/default.conf /etc/nginx/conf.d/default.conf

# 从构建阶段复制前端产物
COPY --from=builder /build/packages/web/dist /usr/share/nginx/html

# Nginx 以非 root 运行的配置（可选加固）
RUN chown -R nginx:nginx /usr/share/nginx/html && \
    chown -R nginx:nginx /var/cache/nginx && \
    chown -R nginx:nginx /var/log/nginx && \
    touch /var/run/nginx.pid && \
    chown -R nginx:nginx /var/run/nginx.pid

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD wget -qO- http://localhost:80/ || exit 1

CMD ["nginx", "-g", "daemon off;"]
